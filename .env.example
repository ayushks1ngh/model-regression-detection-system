# MRDS — Model Regression Detection System
# Copy this file to .env and fill in your values

# Deployment environment: development | test | staging | production
MRDS_ENVIRONMENT=development

# Database
POSTGRES_USER=mrds
POSTGRES_PASSWORD=mrds
POSTGRES_DB=mrds
POSTGRES_PORT=5432

# API
API_PORT=8000

# Worker — set MRDS_WORKER_FAKE_PROVIDER=1 for local smoke testing
# MRDS_WORKER_FAKE_PROVIDER=1

# Provider — required unless MRDS_WORKER_FAKE_PROVIDER is set
# MRDS_OPENROUTER_API_KEY=sk-...

# Logging
MRDS_LOG_LEVEL=INFO
MRDS_LOG_FORMAT=text
